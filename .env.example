APP_NAME=LireX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── MySQL ────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lirex_db
DB_USERNAME=root
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─── Cache / Session / Queue ──────────────────────────────────────────────────
# En local sans Redis : utiliser file
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Avec Redis (optionnel)
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@lirex.africa"
MAIL_FROM_NAME="LireX"

# ─── Stockage ─────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# En production : mettre s3 et remplir les clés ci-dessous
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=lirex-storage

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# ─── MTN Mobile Money ─────────────────────────────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENV=sandbox

# ─── Airtel Money ─────────────────────────────────────────────────────────────
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# ─── Stripe (optionnel) ───────────────────────────────────────────────────────
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_

# ─── SMS Africa's Talking ─────────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=

# ─── Admin par défaut ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@lirex.africa
ADMIN_PASSWORD=LireX@2024!

# ─── Anthropic (IA Review) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Pusher / Laravel Echo (Chat temps réel) ──────────────────────────────────
BROADCAST_DRIVER=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Pour tester sans Pusher : utiliser log
# BROADCAST_DRIVER=log
